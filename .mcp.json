{
  "mcpServers": {
    "neural-memory": {
      "type": "stdio",
      "command": "python",
      "args": ["-m", "neural_memory"],
      "env": {
        "PYTHONPATH": "${CLAUDE_PLUGIN_ROOT}/src",
        "HF_HUB_OFFLINE": "1",
        "TRANSFORMERS_OFFLINE": "1",
        "NEURAL_MEMORY_EMBEDDING_MODEL": "${CLAUDE_PLUGIN_ROOT}/models/paraphrase-multilingual-MiniLM-L12-v2"
      }
    }
  }
}
